#!/bin/sh
set -e

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd -P)"
SCHEME="Veil"
CONFIG="Release"
DEST="platform=macOS"
DERIVED="$PROJECT_DIR/.build"
APP_NAME="Veil.app"
INSTALL_DIR="/Applications"

usage() {
    echo "Usage: $(basename "$0") [--debug] [--install] [--clean]"
    echo "  --debug    Build with Debug configuration"
    echo "  --install  Copy Veil.app to /Applications after build"
    echo "  --clean    Clean before building"
    exit 1
}

INSTALL=false
CLEAN=false

for arg in "$@"; do
    case "$arg" in
        --debug)   CONFIG="Debug" ;;
        --install) INSTALL=true ;;
        --clean)   CLEAN=true ;;
        --help|-h) usage ;;
        *) echo "Unknown option: $arg"; usage ;;
    esac
done

if $CLEAN; then
    echo "Cleaning..."
    xcodebuild clean -project "$PROJECT_DIR/Veil.xcodeproj" -scheme "$SCHEME" -configuration "$CONFIG" -quiet
fi

echo "Building $SCHEME ($CONFIG)..."
xcodebuild build \
    -project "$PROJECT_DIR/Veil.xcodeproj" \
    -scheme "$SCHEME" \
    -configuration "$CONFIG" \
    -destination "$DEST" \
    -derivedDataPath "$DERIVED" \
    -quiet

APP_PATH="$DERIVED/Build/Products/$CONFIG/$APP_NAME"

if [ ! -d "$APP_PATH" ]; then
    echo "Build failed: $APP_PATH not found"
    exit 1
fi

echo "Built: $APP_PATH"

if $INSTALL; then
    TARGET="$INSTALL_DIR/$APP_NAME"
    echo "Installing to $TARGET..."
    rsync -a "$APP_PATH/" "$TARGET/"
    echo "Installed: $TARGET"
fi
